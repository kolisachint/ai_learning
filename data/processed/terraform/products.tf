    {
      name        = "sku"
      type        = "STRING"
      mode        = "REQUIRED"
      description = "Stock-keeping unit code"
    },
    {
      name        = "name"
      type        = "STRING"
      mode        = "REQUIRED"
      description = "Product display name"
    },
    {
      name        = "category"
      type        = "STRING"
      mode        = "NULLABLE"
      description = "Top-level product category"
    },
    {
      name        = "sub_category"
      type        = "STRING"
      mode        = "NULLABLE"
      description = "Product sub-category"
    },
    {
      name        = "price_usd"
      type        = "NUMERIC"
      mode        = "REQUIRED"
      description = "Current list price in USD"
    },
    {
      name        = "stock_qty"
      type        = "INTEGER"
      mode        = "NULLABLE"
      description = "Units available in warehouse"
    },
    {
      name        = "is_active"
