      type        = "TIMESTAMP"
      mode        = "REQUIRED"
      description = "Product listing creation timestamp (UTC)"
    },
    {
      name        = "metadata"
      type        = "JSON"
      mode        = "NULLABLE"
      description = "Arbitrary product attributes"
    }
  ])

  lifecycle {
    prevent_destroy = true
  }
}
